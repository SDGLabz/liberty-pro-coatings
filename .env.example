# ============================================================
# Liberty Pro Coatings — environment variables
# Copy to .env.local for local dev, and set the same keys in the
# Vercel project (Production + Preview) for the live site.
# Without these, the contractor survey returns an honest
# "submissions aren't switched on yet" message (it never fakes success).
# ============================================================

# --- Lead delivery: Resend email ---------------------------------
# Create a key at https://resend.com (Ian already has Resend for the
# AAS + Belzona sites — a new key scoped to this project is cleanest).
RESEND_API_KEY=

# Where contractor-survey leads get emailed (comma-separate for multiple).
LEAD_TO_EMAIL=

# Optional "from" address. Until libertyprocoatings.com is verified in
# Resend, leave this blank and it falls back to onboarding@resend.dev.
# After domain verification, set e.g. "Liberty Pro Coatings <leads@libertyprocoatings.com>".
LEAD_FROM_EMAIL=

# --- Lead delivery: HubSpot form submission ----------------------
# Portal/Hub ID — HubSpot → Settings → Account Setup → Account Defaults
# (also visible in any HubSpot URL: app.hubspot.com/contacts/<PORTAL_ID>/...).
HUBSPOT_PORTAL_ID=

# Form GUID — create a HubSpot form (Marketing → Forms) with these
# default contact fields: Email, First name, Last name, Company name,
# Phone number, State/Region, Message. The GUID is in the form's embed
# code / URL. No private-app token is needed (the v3 form submit endpoint
# is public).
HUBSPOT_FORM_GUID=

# --- SEO canonical (already wired; set at DNS cutover) -----------
# NEXT_PUBLIC_SITE_URL=https://libertyprocoatings.com
